# ============================================================================
# Шаблон .env для backend Django проекту
# Скопіюйте у backend/.env і заповніть своїми значеннями.
# Файл .env у git НЕ потрапляє (див. .gitignore).
# ============================================================================

# Режим розробки (для локального запуску — True)
# Для продакшену обов'язково False!
DEBUG=True

# Секретний ключ Django.
# Згенеруйте новий для продакшену:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-dev-key-CHANGE-ME-in-production-please

# Дозволені хости (через кому, без пробілів)
# Локально: localhost,127.0.0.1
# Прод: dnz52.com.ua,www.dnz52.com.ua
ALLOWED_HOSTS=localhost,127.0.0.1

# CSRF — для HTTPS сайтів (обов'язково для прода з кастомним доменом)
# Приклад: https://dnz52.pythonanywhere.com
CSRF_TRUSTED_ORIGINS=

# CORS — додатково дозволені origins для React фронтенду
# Локальний Vite вже додано автоматично. Тут — продові домени.
# Приклад: https://dnz52-react.vercel.app
CORS_ALLOWED_ORIGINS=

# (опціонально) PostgreSQL для прода:
# DATABASE_URL=postgres://user:password@host:5432/dbname
