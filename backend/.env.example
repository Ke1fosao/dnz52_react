# ============================================================================
# Шаблон .env для backend Django проекту
# Скопіюйте у backend/.env і заповніть своїми значеннями.
# Файл .env у git НЕ потрапляє (див. .gitignore).
# ============================================================================

# Режим розробки (для локального запуску — True)
# Для продакшену обов'язково False!
DEBUG=True

# Секретний ключ Django.
# Згенеруйте новий для продакшену:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-dev-key-CHANGE-ME-in-production-please

# Дозволені хости (через кому, без пробілів)
# Локально: localhost,127.0.0.1
# Прод: dnz52.com.ua,www.dnz52.com.ua
ALLOWED_HOSTS=localhost,127.0.0.1

# CSRF — для HTTPS сайтів (обов'язково для прода з кастомним доменом)
# Приклад: https://dnz52.pythonanywhere.com
CSRF_TRUSTED_ORIGINS=

# CORS — додатково дозволені origins для React фронтенду
# Локальний Vite вже додано автоматично. Тут — продові домени.
# Приклад: https://dnz52-react.vercel.app
CORS_ALLOWED_ORIGINS=

# ----------------------------------------------------------------------------
# База даних: Supabase PostgreSQL (для прода). Якщо не задано — локальний SQLite.
# ----------------------------------------------------------------------------
# ⚠️ ТІЛЬКИ через connection pooler Supabase (він IPv4!). Прямий хост
# db.<ref>.supabase.co лише IPv6 — на PythonAnywhere НЕ працює.
# Пароль зі спецсимволами URL-кодуйте (@ → %40).
# Точний рядок: Supabase → Project Settings → Database → Connection string → "Session pooler".
# DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-1-eu-central-1.pooler.supabase.com:5432/postgres?sslmode=require

# ----------------------------------------------------------------------------
# Медіа: Supabase Storage (S3-сумісне). Якщо AWS_STORAGE_BUCKET_NAME не задано —
# медіа зберігаються локально (зручно для розробки).
# Бакет має бути ПУБЛІЧНИМ: Supabase → Storage → bucket → Make public.
# ----------------------------------------------------------------------------
# AWS_STORAGE_BUCKET_NAME=media
# AWS_S3_ENDPOINT_URL=https://PROJECT_REF.storage.supabase.co/storage/v1/s3
# AWS_S3_REGION_NAME=eu-central-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Web-push (VAPID) — для сповіщень про новини.
# Згенеруйте ключі через: .venv/Scripts/python gen_vapid.py
# PRIVATE — секрет (не публікуйте!), PUBLIC — той самий що VITE_VAPID_PUBLIC_KEY.
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_ADMIN_EMAIL=admin@dnz52.rv.ua

# Google Gemini (ШІ: модерація відгуків + генерація тексту). Без ключа ШІ вимкнено.
GEMINI_API_KEY=
GEMINI_MODELS=gemini-2.5-flash-lite,gemini-2.0-flash-lite,gemini-2.5-flash,gemini-flash-latest

# Безпека (опційно):
# ENFORCE_ADMIN_2FA=True       # вимагати 2FA для входу в Django /admin
# ADMIN_TOKEN_TTL=604800       # термін дії токена React-адмінки, сек (7 діб)
# TURNSTILE_SECRET_KEY=        # Cloudflare Turnstile (captcha форм)
