# API endpoint фронтенду.
# У DEV режимі Vite проксує /api → http://localhost:8000 (див. vite.config.ts).
VITE_API_URL=/api/v1
VITE_MEDIA_URL=/media

# Публічний VAPID-ключ для web-push (той самий що VAPID_PUBLIC_KEY у backend/.env).
# Згенеруйте через: backend/.venv/Scripts/python gen_vapid.py
VITE_VAPID_PUBLIC_KEY=

# (опціонально) Аналітика
VITE_GA_ID=
VITE_PLAUSIBLE_DOMAIN=
