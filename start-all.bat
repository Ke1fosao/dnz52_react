@echo off
REM ============================================================================
REM Запуск обох серверів одночасно (у двох вікнах)
REM ============================================================================

echo Запускаю Django backend у новому вікні...
start "ЗДО №52 — Django Backend" cmd /k "%~dp0start-backend.bat"

echo Чекаю 3 секунди щоб Django піднявся...
timeout /t 3 /nobreak >nul

echo Запускаю React frontend у новому вікні...
start "ЗДО №52 — React Frontend" cmd /k "%~dp0start-frontend.bat"

echo.
echo ============================================================
echo  Готово! Відкрийте у браузері:
echo    http://localhost:5173 — React сайт
echo    http://localhost:8000/admin/ — Django адмінка
echo ============================================================
echo.
echo Натисніть будь-яку кнопку, щоб закрити це вікно
echo (сервери продовжать працювати в окремих вікнах)
pause
